# Copy to .env and fill in real values. Everything runs locally — no cloud accounts needed.

# --- Required to boot the API server ---
PORT=8080
DATABASE_URL=postgres://localhost:5433/vispix
BETTER_AUTH_SECRET=                # generate: openssl rand -hex 32
BETTER_AUTH_URL=http://localhost:8080/api/auth

# --- Object storage (fake-gcs-server via `docker compose up -d`) ---
GCS_ENDPOINT=http://localhost:4443
GCS_BROWSER_UPLOAD_PREFIX=/gcs     # dev-only: browser uploads ride the Vite /gcs proxy (no CORS)
PUBLIC_OBJECT_SEARCH_PATHS=/targetvision/public
PRIVATE_OBJECT_DIR=/targetvision/private

# --- AI providers ---
# AI_KEY_ENCRYPTION_SECRET is required to boot (encrypts admin-entered keys).
# The AI_INTEGRATIONS_* vars below are optional: they're only a fallback used
# when no key is configured in the admin UI (Settings > AI Services), and
# aren't required to start the server. Leave them unset until needed.
AI_KEY_ENCRYPTION_SECRET=          # generate: openssl rand -hex 32
# SESSION_SECRET is an optional fallback: if AI_KEY_ENCRYPTION_SECRET is unset,
# secretCrypto.ts derives the AI-key encryption key from SESSION_SECRET instead.
# Set one or the other. generate: openssl rand -hex 32
# SESSION_SECRET=
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
# AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
# AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com
# AI_INTEGRATIONS_ANTHROPIC_API_KEY=sk-ant-...
# AI_INTEGRATIONS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com
# AI_INTEGRATIONS_GEMINI_API_KEY=...

# --- Image embeddings (Google Vertex AI — semantic photo search & similar photos) ---
# Optional: only needed if you enable image embeddings in Admin > AI Services.
# Auth is Google ADC via a service-account JSON with the "Vertex AI User" role,
# plus your GCP project id and a region where multimodalembedding@001 is
# available (us-central1 is safe). Use forward slashes in the credentials path.
# GOOGLE_APPLICATION_CREDENTIALS=C:/Users/you/.gcp/vertex-embeddings.json
# VERTEX_PROJECT=your-gcp-project-id
# VERTEX_LOCATION=us-central1

# --- Misc ---
# Extra origins allowed to make credentialed API requests / auth requests,
# beyond the localhost:8080/8081 dev defaults. Comma-separated.
CORS_ORIGINS=
TRUSTED_ORIGINS=
LOG_LEVEL=info

# MCP HTTP gateway (remote photo search). Token gates the publicly tunneled
# endpoint — generate with: openssl rand -hex 32. Public URL is the tunnel
# hostname; get_photo download links are built from it.
MCP_AUTH_TOKEN=
MCP_PUBLIC_URL=
