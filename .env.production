# Production Environment Variables for TargetVision
# Copy these to Railway/Render/etc environment variables

# === Application Settings ===
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=warning

# === Database (Railway/Supabase) ===
# Railway will auto-inject DATABASE_URL
# For manual setup:
# DATABASE_URL=postgresql://user:password@host:port/database

# === API URLs ===
# These will be set based on your deployment URLs
BACKEND_URL=https://your-app.railway.app
FRONTEND_URL=https://your-app-frontend.railway.app

# === CORS Configuration ===
# Update with your production domains
CORS_ORIGINS=https://your-app-frontend.railway.app,https://your-custom-domain.com

# === SmugMug OAuth ===
SMUGMUG_API_KEY=your_production_smugmug_key
SMUGMUG_API_SECRET=your_production_smugmug_secret
SMUGMUG_CALLBACK_URL=https://your-app-frontend.railway.app/callback

# === AI API Keys ===
ANTHROPIC_API_KEY=your_production_anthropic_key
OPENAI_API_KEY=your_production_openai_key

# === Security ===
SECRET_KEY=generate_a_secure_random_string_here
JWT_SECRET=another_secure_random_string_here

# === Railway Specific ===
# PORT is automatically set by Railway
# RAILWAY_ENVIRONMENT=production

# === Optional Services ===
# Redis (if using Railway Redis)
# REDIS_URL=redis://default:password@host:port

# === File Storage ===
# For production, consider using S3/Cloudinary
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# CLOUDINARY_URL=

# === Monitoring (Optional) ===
# SENTRY_DSN=your_sentry_dsn_here
# NEW_RELIC_LICENSE_KEY=