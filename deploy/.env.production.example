# Copy to deploy/.env.production and fill in. NEVER commit the real file.
# Generate secrets with:  openssl rand -hex 32

# ---- Postgres (container) ----
POSTGRES_USER=vispix
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_DB=vispix
# Host is the compose service name "postgres", internal port 5432.
DATABASE_URL=postgres://vispix:CHANGE_ME_strong_random_password@postgres:5432/vispix

# ---- API ----
PORT=8080
NODE_ENV=production
BETTER_AUTH_SECRET=CHANGE_ME_64_hex
BETTER_AUTH_URL=https://vispix.dev
CORS_ORIGINS=https://vispix.dev
TRUSTED_ORIGINS=https://vispix.dev
LOG_LEVEL=info
AI_KEY_ENCRYPTION_SECRET=CHANGE_ME_64_hex

# ---- Object storage: REAL GCS (production) ----
# Leave GCS_ENDPOINT and GCS_BROWSER_UPLOAD_PREFIX UNSET — that switches the
# code from the local emulator to real, signature-enforced GCS via the mounted
# service-account key. Replace YOUR_BUCKET with the real private bucket name.
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa.json
PRIVATE_OBJECT_DIR=/YOUR_BUCKET/private
PUBLIC_OBJECT_SEARCH_PATHS=/YOUR_BUCKET/public
VERTEX_PROJECT=targetvision-502503
VERTEX_LOCATION=us-central1

# ---- MCP gateway ----
MCP_HTTP_PORT=8086
MCP_AUTH_TOKEN=CHANGE_ME_random_token
MCP_PUBLIC_URL=https://mcp.vispix.dev

# ---- Stripe billing (uncomment once live keys exist; see DEPLOY.md) ----
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PRO=
# BILLING_PUBLIC_BASE_URL=https://vispix.dev
