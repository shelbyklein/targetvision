# Reference for the DEV preview stack's env file.
#
# The dev stack runs from a separate git worktree at
# C:\Vibes\Targetvision\targetvision-dev and is exposed at
# vispixdev.shelbyklein.com (see docs/DEV_ENVIRONMENT.md).
#
# Setup: in the dev worktree, copy your PROD .env to `.env`, then change ONLY the
# lines marked "DEV OVERRIDE" below. The secrets must stay IDENTICAL to prod so
# cloned sessions / encrypted AI keys still validate.
#
#     cp ../targetvision/.env .env
#     # then edit PORT, DATABASE_URL, BETTER_AUTH_URL, CORS_ORIGINS,
#     # TRUSTED_ORIGINS and add PHOTO_STORAGE_DELETE_DISABLED as below
#
# The dev WEB port (8085) is NOT set here — it's set by the `dev:web:dev` script.
# This PORT value is what the dev API server binds to.

# --- Required to boot the API server ---
PORT=8084                                                    # DEV OVERRIDE (prod: 8080; 8082 is taken)
# DEV OVERRIDE: dev has its OWN database, cloned from prod. Create/refresh it
# with scripts/clone-dev-db.ps1. Schema changes / migrations are safe here.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/vispix_dev
BETTER_AUTH_SECRET=<copy the exact value from your prod .env>            # MUST match prod
BETTER_AUTH_URL=http://localhost:8084/api/auth               # DEV OVERRIDE (prod: 8080)

# --- Object storage (SHARED fake-gcs-server bucket, same as prod) ---
# The dev DB is isolated but its photo rows reference the same image objects
# as prod. PHOTO_STORAGE_DELETE_DISABLED below keeps dev deletes from removing
# files prod still uses.
GCS_ENDPOINT=http://localhost:4443
GCS_BROWSER_UPLOAD_PREFIX=/gcs
PUBLIC_OBJECT_SEARCH_PATHS=/targetvision/public
PRIVATE_OBJECT_DIR=/targetvision/private

# --- AI providers ---
AI_KEY_ENCRYPTION_SECRET=<copy the exact value from your prod .env>      # MUST match prod (decrypts cloned AI keys)

# --- Misc ---
LOG_LEVEL=info
# DEV OVERRIDE: add the dev web origin + dev public hostname so Better Auth
# accepts credentialed requests coming through the dev subdomain.
CORS_ORIGINS=http://localhost:8085,https://vispixdev.shelbyklein.com
TRUSTED_ORIGINS=http://localhost:8085,https://vispixdev.shelbyklein.com

# DEV OVERRIDE (safety): dev's photo rows point at the shared storage bucket;
# deleting photos on dev must not delete image objects prod still references.
PHOTO_STORAGE_DELETE_DISABLED=true

# DEV OVERRIDE: shows the "DEV" badge in the web UI header (issue #130).
# Never set this in the prod .env — prod shows no indicator.
VITE_ENVIRONMENT=dev

# --- Image embeddings (Vertex AI — same as prod) ---
GOOGLE_APPLICATION_CREDENTIALS=C:/Users/sklei/.gcp/vertex-embeddings.json
VERTEX_PROJECT=targetvision-502503
VERTEX_LOCATION=us-central1
