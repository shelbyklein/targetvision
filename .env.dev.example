# Reference for the DEV preview stack's env file.
#
# The dev stack runs from a separate git worktree at
# C:\Vibes\Targetvision\targetvision-dev and is exposed at
# targetvisiondev.shelbyklein.com (see docs/DEV_ENVIRONMENT.md).
#
# Setup: in the dev worktree, copy your PROD .env to `.env`, then change ONLY the
# lines marked "DEV OVERRIDE" below. Everything else (DATABASE_URL, GCS_*,
# secrets) must stay IDENTICAL to prod — the dev stack shares the prod database
# and storage, and reuses the prod secrets so shared sessions / encrypted AI
# keys still validate.
#
#     cp ../targetvision/.env .env
#     # then edit PORT, BETTER_AUTH_URL, CORS_ORIGINS, TRUSTED_ORIGINS as below
#
# The dev WEB port (8085) is NOT set here — it's set by the `dev:web:dev` script.
# This PORT value is what the dev API server binds to.

# --- Required to boot the API server ---
PORT=8084                                                    # DEV OVERRIDE (prod: 8080; 8082 is taken)
DATABASE_URL=postgres://postgres:postgres@localhost:5433/targetvision   # SAME as prod (shared DB)
BETTER_AUTH_SECRET=<copy the exact value from your prod .env>            # MUST match prod
BETTER_AUTH_URL=http://localhost:8084/api/auth               # DEV OVERRIDE (prod: 8080)

# --- Object storage (shared fake-gcs-server, same as prod) ---
GCS_ENDPOINT=http://localhost:4443
GCS_BROWSER_UPLOAD_PREFIX=/gcs
PUBLIC_OBJECT_SEARCH_PATHS=/targetvision/public
PRIVATE_OBJECT_DIR=/targetvision/private

# --- AI providers ---
AI_KEY_ENCRYPTION_SECRET=<copy the exact value from your prod .env>      # MUST match prod (decrypts shared AI keys)

# --- Misc ---
LOG_LEVEL=info
# DEV OVERRIDE: add the dev web origin + dev public hostname so Better Auth
# accepts credentialed requests coming through the dev subdomain.
CORS_ORIGINS=http://localhost:8085,https://targetvisiondev.shelbyklein.com
TRUSTED_ORIGINS=http://localhost:8085,https://targetvisiondev.shelbyklein.com

# --- Image embeddings (Vertex AI — same as prod) ---
GOOGLE_APPLICATION_CREDENTIALS=C:/Users/sklei/.gcp/vertex-embeddings.json
VERTEX_PROJECT=targetvision-502503
VERTEX_LOCATION=us-central1

# --- Migration previews only (see docs/DEV_ENVIRONMENT.md) ---
# Sharing the prod DB is safe for code/UI previews but NOT for branches that
# change the schema. To preview a migration, point dev at an isolated DB
# instead (createdb targetvision_dev first, then run the migration there):
# DATABASE_URL=postgres://postgres:postgres@localhost:5433/targetvision_dev
